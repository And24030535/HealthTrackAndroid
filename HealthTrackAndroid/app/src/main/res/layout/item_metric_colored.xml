<?xml version="1.0" encoding="utf-8"?>
<!--
    El fondo de esta fila se asigna en codigo (ColoredMetricAdapter)
    segun los umbrales clinicos: rojo, ambar o verde oscuro.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="1dp">

    <!-- Franja de color lateral — el adapter asigna su color por codigo -->
    <View
        android:id="@+id/metricColorStripe"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/ht_status_green"/>

    <!-- Contenido de la metrica -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Fecha -->
        <TextView
            android:id="@+id/metricDateTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ht_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp"/>

        <!-- Presion arterial -->
        <TextView
            android:id="@+id/metricBpTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ht_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

        <!-- Frecuencia cardiaca -->
        <TextView
            android:id="@+id/metricHeartRateTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ht_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

        <!-- Glucosa -->
        <TextView
            android:id="@+id/metricGlucoseTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ht_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

        <!-- IMC -->
        <TextView
            android:id="@+id/metricBmiTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ht_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

    </LinearLayout>

</LinearLayout>
