<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ht_bg_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar Métrica"
                android:textColor="@color/ht_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completa los campos de hoy"
                android:textColor="@color/ht_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Tarjeta del formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_login_form"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:padding="24dp">

            <!-- Peso -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PESO (KG)"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/weightEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ej. 72.5"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Presion sistolica -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRESIÓN SISTÓLICA (mmHg)"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/systolicEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ej. 120"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Presion diastolica -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRESIÓN DIASTÓLICA (mmHg)"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/diastolicEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ej. 80"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Frecuencia cardiaca -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FRECUENCIA CARDÍACA (lpm)"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/heartRateEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ej. 72"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Glucosa -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GLUCOSA (mg/dL)"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/glucoseEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ej. 95"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp"/>

            <!-- Boton guardar -->
            <Button
                android:id="@+id/saveMetricButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Guardar Datos"
                android:backgroundTint="@color/ht_primary"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
