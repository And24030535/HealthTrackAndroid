<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ht_bg_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="44dp"
            android:paddingBottom="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear Cuenta"
                android:textColor="@color/ht_text_primary"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HealthTrack Community"
                android:textColor="@color/ht_accent"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Tarjeta del formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_login_form"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:padding="24dp">

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/firstNameEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Tu nombre"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="textPersonName"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Apellido -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APELLIDO"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/lastNameEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Tu apellido"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="textPersonName"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORREO ELECTRÓNICO"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="usuario@correo.com"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Contrasena -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRASEÑA"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Mínimo 6 caracteres"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Altura (necesaria para calcular IMC automáticamente) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALTURA (METROS)"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/heightEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ej. 1.75"
                android:textColorHint="@color/ht_text_hint"
                android:textColor="@color/ht_text_primary"
                android:background="@drawable/bg_input_field"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Fecha de nacimiento -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FECHA DE NACIMIENTO"
                android:textColor="@color/ht_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <Button
                android:id="@+id/birthDateButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Seleccionar fecha"
                android:backgroundTint="@color/ht_bg_input"
                android:textColor="@color/ht_text_hint"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/birthDateTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/ht_accent"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Boton registrarse -->
            <Button
                android:id="@+id/registerButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Crear Cuenta"
                android:backgroundTint="@color/ht_primary"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
