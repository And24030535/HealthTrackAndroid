<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ht_bg_deep">

    <!-- Barra de encabezado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="28dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@color/ht_bg_card">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Historial de Métricas"
            android:textColor="@color/ht_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tus registros de salud en tiempo real"
            android:textColor="@color/ht_text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Leyenda de colores clinicos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#0f1e2e">

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#C0392B"
            android:layout_marginEnd="5dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riesgo alto"
            android:textColor="@color/ht_text_secondary"
            android:textSize="11sp"
            android:layout_marginEnd="14dp"/>

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#E6A817"
            android:layout_marginEnd="5dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IMC elevado"
            android:textColor="@color/ht_text_secondary"
            android:textSize="11sp"
            android:layout_marginEnd="14dp"/>

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#2E7D32"
            android:layout_marginEnd="5dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Normal"
            android:textColor="@color/ht_text_secondary"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Lista de metricas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/historyRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>

</LinearLayout>
